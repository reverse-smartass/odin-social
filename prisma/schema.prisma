// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id             String   @id @default(uuid())
  email          String   @unique
  identifier     String   @unique
  displayName    String?
  about          String?
  password       String   @default("placeholder")
  createdAt      DateTime @default(now())
  profilePicture String?

  sentMessages      Message[]       @relation("SentMessages")
  memberOfChatrooms Chatroom[]      @relation("ChatroomUsers")
  ownedChatrooms    Chatroom[]      @relation("OwnedChatrooms")
  userPosts         Post[]          @relation("UserPosts")
  likedPosts        Post[]          @relation("PostLikes")
  sentRequests      FriendRequest[] @relation("SentRequests")
  receivedRequests  FriendRequest[] @relation("ReceivedRequests")
  following         User[]          @relation("UserFollows")
  followedBy        User[]          @relation("UserFollows")
}

model Chatroom {
  id               String    @id @default(cuid())
  roomName         String?
  isDirect         Boolean   @default(false)
  users            User[]    @relation("ChatroomUsers")
  owner            User      @relation("OwnedChatrooms", fields: [ownerId], references: [id])
  ownerId          String
  chatroomMessages Message[] @relation("ChatroomMessages")
  createdAt        DateTime  @default(now())
}

model Message {
  id         String   @id @default(cuid())
  content    String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  edited     Boolean  @default(false)
  sender     User     @relation("SentMessages", fields: [senderId], references: [id])
  senderId   String
  chatroom   Chatroom @relation("ChatroomMessages", fields: [chatroomId], references: [id], onDelete: Cascade)
  chatroomId String
}

model FriendRequest {
  id         String              @id @default(cuid())
  sender     User                @relation("SentRequests", fields: [senderId], references: [id])
  senderId   String
  receiver   User                @relation("ReceivedRequests", fields: [receiverId], references: [id])
  receiverId String
  status     FriendRequestStatus @default(PENDING)
  createdAt  DateTime            @default(now())

  @@unique([senderId, receiverId])
}

enum FriendRequestStatus {
  PENDING
  ACCEPTED
  REJECTED
}

model Post {
  id        String   @id @default(cuid())
  title     String?
  content   String
  mediaUrl  String?
  author    User     @relation("UserPosts", fields: [authorId], references: [id])
  authorId  String
  Likes     User[]   @relation("PostLikes")
  createdAt DateTime @default(now())
  replyTo   Post?    @relation("PostReply", fields: [replyToId], references: [id], onDelete: Cascade)
  replyToId String?
  replies   Post[]   @relation("PostReply")
}